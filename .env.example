# Discord Bot (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_bot_token_here

# Guild (Server) ID — right-click server name → Copy Server ID (enable Developer Mode first)
GUILD_ID=your_guild_id_here

# Application (Client) ID — from Discord Developer Portal → OAuth2 → Client ID
DISCORD_CLIENT_ID=your_application_client_id_here

# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
